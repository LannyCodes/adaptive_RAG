# 精简版 Dockerfile — 云端 LLM API 部署（无需 Ollama/GPU）
# 适用：2核8G 阿里云 ECS，使用通义千问/DeepSeek 等云端 API
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV TOKENIZERS_PARALLELISM=false
# HuggingFace 镜像（国内加速模型下载）
ENV HF_ENDPOINT=https://hf-mirror.com

WORKDIR /app

# 系统依赖 — 精简安装，避免 OOM
#   build-essential: 编译 numpy/sentence-transformers
#   curl: 健康检查
#   --no-install-recommends: 不装推荐包，节省内存和磁盘
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    make \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 先安装依赖（利用 Docker 缓存层）
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt -i https://mirrors.aliyun.com/pypi/simple/ \
    && rm -rf /root/.cache/pip

# 编译完成后卸载编译工具，节省约 200MB 镜像体积
RUN apt-get purge -y --auto-remove gcc g++ make \
    && rm -rf /var/lib/apt/lists/*

# 复制项目文件
COPY . .

# 数据目录
RUN mkdir -p /app/data /app/data/uploads

# 暴露端口（server.py 默认 8000）
EXPOSE 8000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8000/api/health || exit 1

# 启动命令
CMD ["python", "server.py"]
