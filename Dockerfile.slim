# 精简版 Dockerfile — 云端 LLM API 部署（无需 Ollama/GPU）
# 适用：2核8G 阿里云 ECS，使用通义千问/DeepSeek 等云端 API
FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV TOKENIZERS_PARALLELISM=false
# 抑制 CUDA/absl/protobuf 无关警告
ENV TF_CPP_MIN_LOG_LEVEL=3
ENV TF_ENABLE_ONEDNN_OPTS=0
ENV ABSL_MIN_LOG_LEVEL=3
ENV PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
# HuggingFace 镜像（国内加速模型下载）
ENV HF_ENDPOINT=https://hf-mirror.com

WORKDIR /app

# 换阿里云 Debian 镜像源（国内服务器连官方源超时）
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || \
    sed -i 's|deb.debian.org|mirrors.aliyun.com|g' /etc/apt/sources.list 2>/dev/null || true

# 系统依赖 — 精简安装，避免 OOM
#   gcc/g++/make: 编译 numpy/sentence-transformers
#   curl: 健康检查
#   --no-install-recommends: 不装推荐包，节省内存和磁盘
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    make \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# 先安装依赖（利用 Docker 缓存层）
#   --timeout 120: 增加下载超时到 120 秒
#   --retries 5: 失败重试 5 次
#   --trusted-host: 跳过 SSL 验证（国内镜像偶尔证书问题）
#   备选镜像：清华源 https://pypi.tuna.tsinghua.edu.cn/simple/
COPY requirements.txt .
RUN pip install --no-cache-dir --timeout 120 --retries 5 \
    -r requirements.txt \
    -i https://mirrors.aliyun.com/pypi/simple/ \
    --trusted-host mirrors.aliyun.com \
    || pip install --no-cache-dir --timeout 120 --retries 5 \
    -r requirements.txt \
    -i https://pypi.tuna.tsinghua.edu.cn/simple/ \
    --trusted-host pypi.tuna.tsinghua.edu.cn \
    && rm -rf /root/.cache/pip

# 编译完成后卸载编译工具，节省约 200MB 镜像体积
RUN apt-get purge -y --auto-remove gcc g++ make \
    && rm -rf /var/lib/apt/lists/*

# 复制项目文件
COPY . .

# 数据目录
RUN mkdir -p /app/data /app/data/uploads

# 下载前端依赖（本地化，不依赖外部 CDN）
RUN mkdir -p /app/static && \
    echo "下载 React..." && \
    curl -sL -o /app/static/react.production.min.js \
         https://cdn.staticfile.org/react/18.2.0/umd/react.production.min.js && \
    curl -sL -o /app/static/react-dom.production.min.js \
         https://cdn.staticfile.org/react-dom/18.2.0/umd/react-dom.production.min.js && \
    curl -sL -o /app/static/babel.min.js \
         https://cdn.staticfile.org/babel-standalone/7.23.0/babel.min.js && \
    curl -sL -o /app/static/marked.min.js \
         https://cdn.staticfile.org/marked/9.1.0/marked.min.js && \
    curl -sL -o /app/static/katex.min.css \
         https://cdn.staticfile.org/KaTeX/0.16.9/katex.min.css && \
    curl -sL -o /app/static/katex.min.js \
         https://cdn.staticfile.org/KaTeX/0.16.9/katex.min.js && \
    curl -sL -o /app/static/auto-render.min.js \
         https://cdn.staticfile.org/KaTeX/0.16.9/contrib/auto-render.min.js && \
    curl -sL -o /app/static/fontawesome.min.css \
         https://cdn.staticfile.org/font-awesome/6.4.0/css/all.min.css && \
    curl -sL -o /app/static/tailwind.min.js \
         https://cdn.tailwindcss.com && \
    echo "✅ 前端依赖下载完成"

# 暴露端口（server.py 默认 8000）
EXPOSE 8000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:8000/api/health || exit 1

# 启动命令
CMD ["python", "server.py"]
