# ============================================================
# 自适应 RAG 系统 — 生产环境配置模板
# 使用方法：复制为 .env 后填入真实密钥
#   cp .env.production .env
#   vim .env
# ============================================================

# ---- LLM 后端 ----
# 必填：tongyi（推荐）/ deepseek / ollama
LLM_BACKEND=tongyi

# 通义千问（LLM_BACKEND=tongyi 时必填）
# 获取地址：https://dashscope.console.aliyun.com/apiKey
TONGYI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
TONGYI_MODEL=qwen-plus
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek（LLM_BACKEND=deepseek 时必填）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama（LLM_BACKEND=ollama 时需要，不推荐生产环境使用）
# LOCAL_LLM=qwen2:1.5b

# ---- 网络搜索 ----
# 必填：Tavily API Key
# 获取地址：https://tavily.com/#api
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# ---- 向量数据库 ----
# 方案1：Milvus Lite 本地文件模式（默认，零配置，适合开发和小规模部署）
MILVUS_URI=./milvus_rag.db

# 方案2：Zilliz Cloud 云服务（推荐生产环境，支持大规模数据）
# 获取地址：https://cloud.zilliz.com.cn/
# MILVUS_URI=https://in03-xxxx.serverless.ali-cn-hangzhou.cloud.zilliz.com.cn
# MILVUS_PASSWORD=your_zilliz_api_key

# 方案3：自建 Milvus Server（Docker/K8s）
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_USER=root
# MILVUS_PASSWORD=milvus

# ---- 功能开关（生产环境推荐配置）----
# 关闭多模态（节省 ~600MB 内存，半成品功能未完整实现）
ENABLE_MULTIMODAL=false
# 关闭高级重排器（节省 ~200MB 内存，基础重排已够用）
ENABLE_ADVANCED_RERANKER=false
# 开启混合检索（推荐）
ENABLE_HYBRID_SEARCH=true
# 开启查询扩展（推荐）
ENABLE_QUERY_EXPANSION=true
# 开启 GraphRAG（需要更多内存，按需开启）
ENABLE_GRAPH_RAG=true

# ---- LangSmith 追踪（可选）----
# 获取地址：https://smith.langchain.com/
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxx
# LANGSMITH_TRACING=True
# LANGSMITH_PROJECT=adaptive-rag-prod
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Elasticsearch（可选，大规模 BM25 检索）----
# ES_URL=http://localhost:9200
# ES_USER=elastic
# ES_PASSWORD=changeme
